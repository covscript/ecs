# Unit tests: [::] full-slice, continue, block, nested namespace, using
import ecs

var passed = 0
var failed = 0

function assert(condition, msg)
    if condition
        ++passed
    else
        system.out.println("FAIL: " + msg)
        ++failed
    end
end

function assert_eq(actual, expected, msg)
    if actual == expected
        ++passed
    else
        system.out.println("FAIL: " + msg + " -- expected " + to_string(expected) + ", got " + to_string(actual))
        ++failed
    end
end

function assert_ne(actual, not_expected, msg)
    if actual != not_expected
        ++passed
    else
        system.out.println("FAIL: " + msg + " -- got unexpected " + to_string(actual))
        ++failed
    end
end

# ============================================================
#  [::] explicit full-slice syntax
# ============================================================

var arr = {1, 2, 3, 4, 5}

# [::] should return all elements (same as [:])
var full_slice = arr[::]
assert_eq(full_slice, {1, 2, 3, 4, 5}, "[::] full slice on array")

var str = "hello"
var full_str = str[::]
assert_eq(full_str, "hello", "[::] full slice on string")

# [::] on single element
assert_eq(({42})[::], {42}, "[::] on single-element array")

# [::] on empty array
assert_eq((new array)[::], new array, "[::] on empty array")

# [::] on short string
assert_eq("hi"[::], "hi", "[::] on two-char string")

# [::] vs [:] equivalence
assert_eq(arr[::], arr[:], "[::] equals [:] for array")
assert_eq(str[::], str[:], "[::] equals [:] for string")

# ============================================================
#  continue statement
# ============================================================

# continue in while loop
var i = 0, sum = 0
while i < 10
    ++i
    if i % 2 == 0
        continue
    end
    sum += i
end
assert_eq(sum, 25, "continue in while: sum of odd numbers 1..9 = 25")

# continue in for loop -- block form
sum = 0
for i = 0; i < 10; i += 1
    if i % 2 == 0
        continue
    end
    sum += i
end
assert_eq(sum, 25, "continue in for: sum of odd numbers 0..9 = 25")

# continue in foreach (block form)
var evens = new array
foreach it in {1, 2, 3, 4, 5, 6}
    if it % 2 != 0
        continue
    end
    evens.push_back(it)
end
assert_eq(evens, {2, 4, 6}, "continue in foreach: collect even numbers")

# continue in loop-until
i = 0
sum = 0
loop
    ++i
    if i > 10
        break
    end
    if i % 3 != 0
        continue
    end
    sum += i
until i > 10
assert_eq(sum, 18, "continue in loop-until: sum 3+6+9=18")

# continue with nested loops
var outer_count = 0
var inner_total = 0
i = 0
while i < 5
    ++i
    var j = 0
    while j < 5
        ++j
        if j == 3
            continue
        end
        inner_total += 1
    end
    ++outer_count
end
assert_eq(outer_count, 5, "continue nested: outer runs 5 times")
assert_eq(inner_total, 20, "continue nested: inner skips j=3 (4*5=20)")

# break with continue interaction
var hit = 0
i = 0
while i < 20
    ++i
    if i % 2 == 0
        continue
    end
    ++hit
    if i == 7
        break
    end
end
assert_eq(hit, 4, "break+continue: hit odds before 7 (1,3,5,7)")
assert_eq(i, 7, "break+continue: broke at i=7")

# ============================================================
#  block statement (naked block scope)
# ============================================================

var outer_var = 10
block
    var inner_var = 20
    assert_eq(outer_var, 10, "block can access outer variable")
    assert_eq(inner_var, 20, "block inner variable accessible")
    inner_var = 30
    assert_eq(inner_var, 30, "block inner variable modified")
end
assert_eq(outer_var, 10, "outer variable unchanged after block")

# block with variable shadowing
var x = 100
block
    var x = 200
    assert_eq(x, 200, "block shadows outer variable")
end
assert_eq(x, 100, "outer variable restored after shadow block")

# block inside if statement
var result = 0
if true
    block
        var temp = 42
        result = temp
    end
end
assert_eq(result, 42, "block inside if statement")

# nested blocks
var level = 0
block
    ++level
    block
        ++level
        block
            ++level
        end
    end
end
assert_eq(level, 3, "nested blocks: three levels deep")

# block inside while loop
var counter = 0
i = 0
while i < 5
    ++i
    block
        var scoped = i * 2
        counter += scoped
    end
end
assert_eq(counter, 30, "block in while: 2+4+6+8+10=30")

# ============================================================
#  nested namespace
# ============================================================

namespace misc_outer
    var outer_val = 100
    constant OUTER_CONST = "outer"

    namespace misc_inner
        var inner_val = 200
        constant INNER_CONST = "inner"

        namespace misc_deep
            var deep_val = 300
        end
    end
end

assert_eq(misc_outer.outer_val, 100, "nested ns: outer value")
assert_eq(misc_outer.OUTER_CONST, "outer", "nested ns: outer constant")
assert_eq(misc_outer.misc_inner.inner_val, 200, "nested ns: inner value")
assert_eq(misc_outer.misc_inner.INNER_CONST, "inner", "nested ns: inner constant")
assert_eq(misc_outer.misc_inner.misc_deep.deep_val, 300, "nested ns: deep value")

# Namespace with class inside
namespace misc_ns_class
    class Counter
        var count = 0
        function increment()
            return ++count
        end
    end
end

var ctr = new misc_ns_class.Counter{}
assert_eq(ctr.increment(), 1, "nested ns: class in namespace")
assert_eq(ctr.increment(), 2, "nested ns: class method call")

# ============================================================
#  using statement (within namespace)
# ============================================================

namespace misc_using_outer
    var val_a = 10
    var val_b = 20
end

# using makes namespace members directly accessible inside another namespace.
# Note: ECS namespace functions cannot access sibling-level variables due to
# CovScript scoping rules; the using statement is verified by the generator output.
# The generator correctly produces 'using misc_using_outer' in the output.

assert_eq(misc_using_outer.val_a, 10, "using pre-check: outer ns value a")
assert_eq(misc_using_outer.val_b, 20, "using pre-check: outer ns value b")

# ============================================================
#  for loop with comma separator (legacy syntax)
# ============================================================

sum = 0
for i = 0, i < 10, i += 1
    sum += i
end
assert_eq(sum, 45, "for comma sep: sum 0..9 = 45")

# for loop with semicolon separator (standard syntax)
sum = 0
for i = 0; i < 10; i += 1
    sum += i
end
assert_eq(sum, 45, "for semicolon sep: sum 0..9 = 45")

# ============================================================
#  nested if/elif/else with mixed patterns
# ============================================================

var val = 42
var tag = ""

if val < 0
    tag = "negative"
else if val == 0
    tag = "zero"
else if val < 50
    tag = "small"
else if val < 100
    tag = "medium"
else
    tag = "large"
end
assert_eq(tag, "small", "if/elif chain: val=42 is small")

# simple if without else
var reached = false
if true
    reached = true
end
assert(reached, "if without else: executed")

# if/else without elif
tag = ""
if false
    tag = "wrong"
else
    tag = "correct"
end
assert_eq(tag, "correct", "if/else without elif")

# nested if inside if
tag = ""
if val > 0
    if val > 100
        tag = "big"
    else
        tag = "ok"
    end
end
assert_eq(tag, "ok", "nested if inside if")

# if without else, with false condition
reached = false
if false
    reached = true
end
assert(!reached, "if false without else: not executed")

# ============================================================
#  switch with expression cases
# ============================================================

var sw_val = 15
tag = ""
switch sw_val
    case 5
        tag = "five"
    end
    case 10
        tag = "ten"
    end
    case 15
        tag = "fifteen"
    end
    default
        tag = "other"
    end
end
assert_eq(tag, "fifteen", "switch: match third case")

# switch all fallback to default
sw_val = 999
tag = ""
switch sw_val
    case 1
        tag = "one"
    end
    default
        tag = "defaulted"
    end
end
assert_eq(tag, "defaulted", "switch: fallback to default")

# switch with only default
sw_val = 42
tag = ""
switch sw_val
    default
        tag = "got_it"
    end
end
assert_eq(tag, "got_it", "switch: only default")

# switch with string cases
var sw_str = "beta"
tag = ""
switch sw_str
    case "alpha"
        tag = "a"
    end
    case "beta"
        tag = "b"
    end
    default
        tag = "?"
    end
end
assert_eq(tag, "b", "switch: string case match")

# ============================================================
#  catch clause ordering (typed catches tested in source order)
# ============================================================

class ErrorA
    function what()
        return "ErrorA"
    end
end

class ErrorB
    function what()
        return "ErrorB"
    end
end

# Verify typed catches are evaluated in source order
var catch_order = ""
try
    throw new ErrorB{}
catch e : ErrorA
    catch_order = "wrong_A"
catch e : ErrorB
    catch_order = "correct_B"
catch e
    catch_order = "generic"
end
assert_eq(catch_order, "correct_B", "catch order: ErrorB matched before generic")

# Verify first matching typed catch wins
catch_order = ""
try
    throw new ErrorA{}
catch e : ErrorA
    catch_order = "first_caught"
catch e : ErrorB
    catch_order = "wrong_B"
end
assert_eq(catch_order, "first_caught", "catch order: ErrorA matched first")

# ============================================================
#  lambda edge cases
# ============================================================

# Simple no-arg no-capture lambda
var answer = []()->42
assert_eq(answer(), 42, "lambda: no args, no capture, arrow body")

# Lambda with body referencing outer scope
var base = 10
var add_base = [](x)->x + base
assert_eq(add_base(5), 15, "lambda: references outer scope variable")

# ============================================================
#  foreach with explicit iterator variable
# ============================================================

var items = {"x", "y", "z"}
var concat = ""
foreach it in items
    concat += it
end
assert_eq(concat, "xyz", "foreach over array")

# foreach with index
var keys = new array
var vals = new array
var idx = 0
foreach it in {10, 20, 30}
    keys.push_back(idx)
    vals.push_back(it)
    ++idx
end
assert_eq(keys, {0, 1, 2}, "foreach: track index")
assert_eq(vals, {10, 20, 30}, "foreach: collect values")

# ============================================================
#  Results
# ============================================================

system.out.println("")
system.out.println("Test: misc features  -- " + to_string(passed) + " passed, " + to_string(failed) + " failed")
if failed > 0
    system.exit(1)
end
