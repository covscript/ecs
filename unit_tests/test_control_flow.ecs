# Unit tests: Control flow (if/else, while, for, foreach, loop-until, switch)
import ecs

var passed = 0
var failed = 0

function assert(condition, msg)
    if condition
        ++passed
    else
        system.out.println("FAIL: " + msg)
        ++failed
    end
end

function assert_eq(actual, expected, msg)
    if actual == expected
        ++passed
    else
        system.out.println("FAIL: " + msg + " -- expected " + to_string(expected) + ", got " + to_string(actual))
        ++failed
    end
end

# ---- if / else ----
var x = 10
var r = 0
if x > 5
    r = 1
else if x > 15
    r = 2
else
    r = 3
end
assert_eq(r, 1, "if branch (x > 5)")

x = 3
if x > 5
    r = 1
else if x > 0
    r = 2
else
    r = 3
end
assert_eq(r, 2, "else-if branch (x > 0)")

x = -1
if x > 5
    r = 1
else
    r = 3
end
assert_eq(r, 3, "else branch")

# ---- while ----
var i = 0, sum = 0
while i < 5
    sum += i
    ++i
end
assert_eq(sum, 10, "while loop sum [0..4]")

# ---- for (ECS for-do syntax) ----
sum = 0
for i = 0; i < 5; i += 1 do sum += i
assert_eq(sum, 10, "for loop sum [0..4]")

# ---- foreach ----
var arr = {10, 20, 30}
sum = 0
foreach it in arr do sum += it
assert_eq(sum, 60, "foreach array sum")

# ---- loop-until ----
i = 0
sum = 0
loop
    sum += i
    ++i
until i >= 5
assert_eq(sum, 10, "loop-until sum [0..4]")

# ---- switch ----
x = 2
r = -1
switch x
    case 1
        r = 10
    end
    case 2
        r = 20
    end
    default
        r = 30
    end
end
assert_eq(r, 20, "switch case match (2)")

x = 99
r = -1
switch x
    case 1
        r = 10
    end
    default
        r = 30
    end
end
assert_eq(r, 30, "switch default fallback")

# ---- break ----
sum = 0
i = 0
while i < 10
    if i == 5
        break
    end
    sum += i
    ++i
end
assert_eq(sum, 10, "break in while loop [0..4]")

# ---- Results ----
system.out.println("")
system.out.println("Test: control flow  -- " + to_string(passed) + " passed, " + to_string(failed) + " failed")
if failed > 0
    system.exit(1)
end
